function updateServerInfo()
    pcall(function()
        jobIdLabel.Text = "Job ID: " .. (game.JobId or "Offline")
        playersLabel.Text = "Players: " .. #Players:GetPlayers() .. " / " .. Players.MaxPlayers
        pingLabel.Text = "Ping: " .. math.floor(LocalPlayer:GetNetworkPing() * 1000) .. " ms"
        statusLabel.Text = "Status: ONLINE"
    end)
end

function updatePlayersList()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do
        table.insert(names, p.Name)
    end
    if #names == 0 then table.insert(names, "No players") end
    setPlayersDropdown(names, function(selected)
        local player = Players:FindFirstChild(selected)
        if player then
            local info = string.format("Name: %s\nDisplay: %s\nAccount Age: %d days\nTeam: %s",
                player.Name, player.DisplayName or player.Name, player.AccountAge or 0,
                (player.Team and player.Team.Name) or "No team")
            infoTextField.Text = info
            print(info)
            notify("Player Info", player.Name .. ": " .. (player.AccountAge or 0) .. " days", 3)
        end
    end)
end


-- --- Функция для безопасного копирования текста (JobId) ---
local function copyToClipboard(text)
    -- Для мобильных исполнителей часто требуется setclipboard или toclipboard
    if setclipboard then
        setclipboard(text)
    elseif toclipboard then
        toclipboard(text)
    else
        -- Если функции нет, используем GUI нотификацию
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Ошибка",
            Text = "Ваш исполнитель не поддерживает копирование в буфер",
            Duration = 3
        })
        return
    end
    
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Скопировано",
        Text = "JobId: " .. text,
        Duration = 2
    })
end


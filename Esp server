-- --- Функция Остановки спекта (возврат камеры) ---
local function stopSpectate()
    if spectateConnection then
        spectateConnection:Disconnect()
        spectateConnection = nil
    end
    
    if currentSpectateTarget then
        currentSpectateTarget = nil
        -- Возвращаем камеру в обычный режим
        if originalCameraType then
            Camera.CameraType = originalCameraType
        else
            Camera.CameraType = Enum.CameraType.Custom
        end
        Camera.CFrame = originalCameraCFrame or CFrame.new()
        
        -- Сообщаем пользователю об остановке
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Spectate",
            Text = "Слежение остановлено. Камера возвращена.",
            Duration = 2
        })
    end
end

-- --- Функция Запуска спекта за выбранным игроком ---
local function startSpectate(targetPlayer)
    -- Проверка валидности игрока и его персонажа
    if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Ошибка",
            Text = "Игрок не найден или персонаж не загружен",
            Duration = 2
        })
        return false
    end
    
    -- Останавливаем текущий спект, если он был
    if currentSpectateTarget then
        stopSpectate()
    end
    
    -- Сохраняем настройки камеры до спекта
    originalCameraType = Camera.CameraType
    originalCameraCFrame = Camera.CFrame
    
    -- Делаем камеру управляемой скриптом
    Camera.CameraType = Enum.CameraType.Scriptable
    
    currentSpectateTarget = targetPlayer
    
    -- Плавное следование камеры (Lerp / Tween) для производительности [citation:3]
    -- Используем RenderStepped для максимальной плавности, но ограничиваем обновления через Tween
    local lastCFrame = nil
    
    spectateConnection = RunService.RenderStepped:Connect(function(deltaTime)
        if not currentSpectateTarget then return end
        
        -- Проверяем, существует ли персонаж игрока
        local character = currentSpectateTarget.Character
        if not character then return end
        
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        -- Позиция, на которую должна смотреть камера (чуть выше головы игрока)
        local targetCFrame = rootPart.CFrame + rootPart.CFrame.UpVector * 2
        
        -- Используем Tween для плавности, чтобы избежать рывков на слабых устройствах [citation:3]
        -- Для оптимизации: не создаем твин каждый кадр, а обновляем через CFrame:Lerp
        -- Это более производительно, чем постоянное создание объектов Tween
        
        if not lastCFrame then
            Camera.CFrame = targetCFrame
        else
            -- Линейная интерполяция для плавности (скорость 0.2)
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 0.2)
        end
        lastCFrame = targetCFrame
    end)
    
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Spectate",
        Text = "Слежение за: " .. targetPlayer.Name,
        Duration = 2
    })
    
    return true
end


--[[
    Script: Mobile Admin Hub
    Executor: Delta / Fluxus (Mobile)
    Optimized for: Realme, Xiaomi, Samsung
    Version: 2.0
--]]

-- Load Rayfield Library
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

if not Rayfield then
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Error",
        Text = "Failed to load Rayfield",
        Duration = 5
    })
    return
end

-- Services
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

-- Variables
local currentSpectateTarget = nil
local spectateConnection = nil
local originalCameraType = nil
local originalCameraCFrame = nil
local isSpectating = false

-- Copy to clipboard
local function copyToClipboard(text)
    local success = false
    
    if setclipboard then
        success = pcall(setclipboard, text)
    elseif toclipboard then
        success = pcall(toclipboard, text)
    elseif writefile then
        success = pcall(writefile, "temp.txt", text)
        if success then
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Saved",
                Text = "JobId saved to temp.txt",
                Duration = 3
            })
            return
        end
    end
    
    if success then
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Copied",
            Text = "JobId: " .. text,
            Duration = 2
        })
    else
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Error",
            Text = "Copy not supported",
            Duration = 3
        })
    end
end

-- Update server info
local function updateServerInfo()
    task.spawn(function()
        pcall(function()
            local jobId = game.JobId or "Offline"
            local playerCount = #Players:GetPlayers()
            local maxPlayers = Players.MaxPlayers
            local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000) .. " ms"
            
            Rayfield:SetElementFlagValue("Server_JobId", jobId)
            Rayfield:SetElementFlagValue("Server_Players", playerCount .. " / " .. maxPlayers)
            Rayfield:SetElementFlagValue("Server_Ping", ping)
        end)
    end)
end

-- Refresh players dropdown
local function refreshPlayersDropdown()
    local playerNames = {}
    for _, player in ipairs(Players:GetPlayers()) do
        table.insert(playerNames, player.Name)
    end
    
    if #playerNames == 0 then
        playerNames = {"No players"}
    end
    
    Rayfield:SetElementFlagValue("Players_Dropdown", {
        Options = playerNames,
        CurrentOption = {playerNames[1]}
    })
end

-- Get player info
local function getPlayerInfo(player)
    if not player then return "Player not found" end
    
    local accountAge = player.AccountAge or 0
    local displayName = player.DisplayName or player.Name
    local team = player.Team
    local teamName = team and team.Name or "No team"
    
    local infoText = string.format(
        "Name: %s\nDisplay: %s\nAccount Age: %d days\nTeam: %s",
        player.Name, displayName, accountAge, teamName
    )
    
    return infoText
end

-- Stop spectate
local function stopSpectate()
    if spectateConnection then
        spectateConnection:Disconnect()
        spectateConnection = nil
    end
    
    if isSpectating then
        isSpectating = false
        
        if originalCameraType then
            Camera.CameraType = originalCameraType
        else
            Camera.CameraType = Enum.CameraType.Custom
        end
        
        if originalCameraCFrame then
            Camera.CFrame = originalCameraCFrame
        end
        
        currentSpectateTarget = nil
        
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Spectate",
            Text = "Spectate stopped",
            Duration = 2
        })
    end
end

-- Start spectate
local function startSpectate(targetPlayer)
    if not targetPlayer then return false end
    
    if isSpectating then
        stopSpectate()
    end
    
    local character = targetPlayer.Character
    if not character then
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Error",
            Text = "Character not loaded",
            Duration = 2
        })
        return false
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    originalCameraType = Camera.CameraType
    originalCameraCFrame = Camera.CFrame
    
    Camera.CameraType = Enum.CameraType.Scriptable
    
    currentSpectateTarget = targetPlayer
    isSpectating = true
    
    spectateConnection = RunService.RenderStepped:Connect(function()
        if not isSpectating or not currentSpectateTarget then return end
        
        local char = currentSpectateTarget.Character
        if not char then return end
        
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        
        local targetCFrame = root.CFrame + root.CFrame.UpVector * 2.5
        Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 0.25)
    end)
    
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Spectate",
        Text = "Spectating: " .. targetPlayer.Name,
        Duration = 2
    })
    
    return true
end

-- Show player info
local function showPlayerInfo(playerName)
    local player = Players:FindFirstChild(playerName)
    if not player then return end
    
    local infoText = getPlayerInfo(player)
    
    print(infoText)
    
    pcall(function()
        Rayfield:SetElementFlagValue("Player_Info_Text", infoText)
    end)
    
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Player Info",
        Text = player.Name .. ": " .. player.AccountAge .. " days",
        Duration = 3
    })
end

-- Create UI
local Window = Rayfield:CreateWindow({
    Name = "Mobile Hub",
    Icon = 0,
    LoadingTitle = "Loading",
    LoadingSubtitle = "Optimized for mobile",
    Theme = "Dark",
    ToggleUIKeybind = Enum.KeyCode.K,
    ConfigurationSaving = {
        Enabled = false
    },
    KeySystem = false
})

-- Server Tab
local ServerTab = Window:CreateTab("Server", nil)

ServerTab:CreateSection("Server Info")

ServerTab:CreateParagraph({
    Name = "Job ID",
    Flag = "Server_JobId",
    Value = "Loading..."
})

ServerTab:CreateParagraph({
    Name = "Players",
    Flag = "Server_Players",
    Value = "0 / 0"
})

ServerTab:CreateParagraph({
    Name = "Ping",
    Flag = "Server_Ping",
    Value = "0 ms"
})

ServerTab:CreateButton({
    Name = "Copy JobId",
    Flag = "CopyJobId",
    Callback = function()
        copyToClipboard(game.JobId or "No JobId")
    end
})

-- Players Tab
local PlayersTab = Window:CreateTab("Players", nil)

PlayersTab:CreateSection("Management")

PlayersTab:CreateButton({
    Name = "Refresh List",
    Flag = "RefreshPlayers",
    Callback = function()
        refreshPlayersDropdown()
    end
})

PlayersTab:CreateDropdown({
    Name = "Select Player",
    Flag = "Players_Dropdown",
    Options = {"Loading..."},
    CurrentOption = {"Loading..."},
    MultipleOptions = false,
    Callback = function(selected)
        if selected and #selected > 0 then
            showPlayerInfo(selected[1])
        end
    end
})

PlayersTab:CreateParagraph({
    Name = "Player Info",
    Flag = "Player_Info_Text",
    Value = "Select a player from the list"
})

local spectateToggle = PlayersTab:CreateToggle({
    Name = "Spectate",
    Flag = "SpectateToggle",
    CurrentValue = false,
    Callback = function(enabled)
        if enabled then
            local dropdown = Rayfield:GetElementFlagValue("Players_Dropdown")
            if dropdown and #dropdown > 0 then
                local target = Players:FindFirstChild(dropdown[1])
                if target then
                    startSpectate(target)
                else
                    spectateToggle:Set(false)
                    game:GetService("StarterGui"):SetCore("SendNotification", {
                        Title = "Error",
                        Text = "Player not found",
                        Duration = 2
                    })
                end
            else
                spectateToggle:Set(false)
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "Error",
                    Text = "Select a player first",
                    Duration = 2
                })
            end
        else
            stopSpectate()
        end
    end
})

-- Background tasks
task.spawn(function()
    while task.wait(2) do
        updateServerInfo()
    end
end)

task.spawn(function()
    while task.wait(5) do
        refreshPlayersDropdown()
    end
end)

-- Events
Players.PlayerRemoving:Connect(function(player)
    if currentSpectateTarget == player then
        if spectateToggle then
            spectateToggle:Set(false)
        else
            stopSpectate()
        end
        refreshPlayersDropdown()
    end
end)

Players.PlayerAdded:Connect(function()
    refreshPlayersDropdown()
end)

-- Startup
task.wait(0.5)
updateServerInfo()
refreshPlayersDropdown()

print("Mobile Hub loaded! Press K to toggle UI")

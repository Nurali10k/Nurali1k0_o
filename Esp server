-- === ФУНКЦИИ СПЕКТА ===
function stopSpectate()
    if spectateConnection then
        spectateConnection:Disconnect()
        spectateConnection = nil
    end
    
    if isSpectating then
        isSpectating = false
        if originalCameraType then
            Camera.CameraType = originalCameraType
        else
            Camera.CameraType = Enum.CameraType.Custom
        end
        if originalCameraCFrame then
            Camera.CFrame = originalCameraCFrame
        end
        currentSpectateTarget = nil
        notify("Spectate", "Spectate stopped", 2)
    end
end

function startSpectate(target)
    if isSpectating then stopSpectate() end
    
    local character = target.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        notify("Error", "Character not loaded", 2)
        return false
    end
    
    originalCameraType = Camera.CameraType
    originalCameraCFrame = Camera.CFrame
    Camera.CameraType = Enum.CameraType.Scriptable
    
    currentSpectateTarget = target
    isSpectating = true
    
    spectateConnection = RunService.RenderStepped:Connect(function()
        if not isSpectating or not currentSpectateTarget then
            stopSpectate()
            return
        end
        local char = currentSpectateTarget.Character
        if not char then stopSpectate() return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then stopSpectate() return end
        local targetCFrame = root.CFrame + root.CFrame.UpVector * 2.5
        Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 0.25)
    end)
    
    notify("Spectate", "Spectating: " .. target.Name, 2)
    return true
end


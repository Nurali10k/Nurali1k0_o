local function createDropdown(parent, items, yPos, callback)
    local dropdownFrame = Instance.new("Frame")
    dropdownFrame.Size = UDim2.new(1, -20, 0, 40)
    dropdownFrame.Position = UDim2.new(0, 10, 0, yPos)
    dropdownFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
    dropdownFrame.Parent = parent
    
    local dropdownCorners = Instance.new("UICorner")
    dropdownCorners.CornerRadius = UDim.new(0, 8)
    dropdownCorners.Parent = dropdownFrame
    
    local selectedLabel = Instance.new("TextLabel")
    selectedLabel.Size = UDim2.new(1, -30, 1, 0)
    selectedLabel.BackgroundTransparency = 1
    selectedLabel.Text = items[1] or "No players"
    selectedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    selectedLabel.TextSize = 14
    selectedLabel.Font = Enum.Font.Gotham
    selectedLabel.TextXAlignment = Enum.TextXAlignment.Left
    selectedLabel.Parent = dropdownFrame
    
    local arrow = Instance.new("TextLabel")
    arrow.Size = UDim2.new(0, 30, 1, 0)
    arrow.Position = UDim2.new(1, -30, 0, 0)
    arrow.BackgroundTransparency = 1
    arrow.Text = "▼"
    arrow.TextColor3 = Color3.fromRGB(200, 200, 200)
    arrow.TextSize = 14
    arrow.Parent = dropdownFrame
    
    local dropdownList = Instance.new("Frame")
    dropdownList.Size = UDim2.new(1, 0, 0, 0)
    dropdownList.Position = UDim2.new(0, 0, 1, 0)
    dropdownList.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    dropdownList.Visible = false
    dropdownList.ClipsDescendants = true
    dropdownList.Parent = dropdownFrame
    
    local listCorners = Instance.new("UICorner")
    listCorners.CornerRadius = UDim.new(0, 8)
    listCorners.Parent = dropdownList
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 2)
    listLayout.Parent = dropdownList
    
    local function updateList(newItems)
        for _, child in ipairs(dropdownList:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        
        for i, item in ipairs(newItems) do
            local optionBtn = Instance.new("TextButton")
            optionBtn.Size = UDim2.new(1, 0, 0, 35)
            optionBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
            optionBtn.Text = item
            optionBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            optionBtn.TextSize = 13
            optionBtn.Font = Enum.Font.Gotham
            optionBtn.Parent = dropdownList
            
            optionBtn.MouseButton1Click:Connect(function()
                selectedLabel.Text = item
                dropdownList.Visible = false
                dropdownFrame.Size = UDim2.new(1, -20, 0, 40)
                callback(item)
            end)
        end
        
        dropdownList.CanvasSize = UDim2.new(0, 0, 0, #newItems * 37)
    end
    
    dropdownFrame.MouseButton1Click:Connect(function()
        if dropdownList.Visible then
            dropdownList.Visible = false
            dropdownFrame.Size = UDim2.new(1, -20, 0, 40)
        else
            dropdownList.Visible = true
            dropdownFrame.Size = UDim2.new(1, -20, 0, 40 + math.min(#items * 37, 200))
        end
    end)
    
    updateList(items)
    
    return {
        update = updateList,
        getValue = function() return selectedLabel.Text end
    }
end

local function createToggle(parent, text, yPos, callback)
    local toggleFrame = Instance.new("Frame")
    toggleFrame.Size = UDim2.new(1, -20, 0, 40)
    toggleFrame.Position = UDim2.new(0, 10, 0, yPos)
    toggleFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
    toggleFrame.Parent = parent
    
    local toggleCorners = Instance.new("UICorner")
    toggleCorners.CornerRadius = UDim.new(0, 8)
    toggleCorners.Parent = toggleFrame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -50, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 14
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = toggleFrame
    
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 50, 0, 30)
    toggleBtn.Position = UDim2.new(1, -55, 0.5, -15)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 120)
    toggleBtn.Text = "OFF"
    toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggleBtn.TextSize = 12
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.Parent = toggleFrame
    
    local btnCorners = Instance.new("UICorner")
    btnCorners.CornerRadius = UDim.new(0, 15)
    btnCorners.Parent = toggleBtn
    
    local state = false
    
    toggleBtn.MouseButton1Click:Connect(function()
        state = not state
        if state then
            toggleBtn.BackgroundColor3 = Color3.fromRGB(76, 175, 80)
            toggleBtn.Text = "ON"
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 120)
            toggleBtn.Text = "OFF"
        end
        callback(state)
    end)
    
    return {
        set = function(newState)
            state = newState
            if state then
                toggleBtn.BackgroundColor3 = Color3.fromRGB(76, 175, 80)
                toggleBtn.Text = "ON"
            else
                toggleBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 120)
                toggleBtn.Text = "OFF"
            end
        end
    }
end


local function updateHP()
    local char = LocalPlayer.Character
    if not char then
        HPLabel.Text = "❤️ HP: —"
        HPBar.Size   = UDim2.new(0, 0, 1, 0)
        return
    end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        local hp    = math.floor(hum.Health)
        local maxHP = math.floor(hum.MaxHealth)
        local pct   = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        HPLabel.Text = string.format("❤️  HP: %d / %d", hp, maxHP)

        local col
        if pct > 0.6 then
            col = Color3.fromRGB(80, 230, 100)
        elseif pct > 0.3 then
            col = Color3.fromRGB(255, 180, 0)
        else
            col = Color3.fromRGB(220, 50, 50)
        end
        HPBar.BackgroundColor3 = col

        TweenService:Create(HPBar, TweenInfo.new(0.3), {
            Size = UDim2.new(pct, 0, 1, 0)
        }):Play()
    end
end

RunService.Heartbeat:Connect(updateHP)


local bringPage = newPage("Bring")

local function getTargetCF()
    local root = getRoot()
    if not root then return CFrame.new(0,100,0) end
    if State.BringTarget == "Player" then
        return root.CFrame
    elseif State.BringTarget == "Workbench" then
        local wb = workspace:FindFirstChild("Workbench", true)
        if wb and wb:IsA("BasePart") then return wb.CFrame end
    elseif State.BringTarget == "Campfire" then
        local cf = workspace:FindFirstChild("Campfire", true)
        if cf and cf:IsA("BasePart") then return cf.CFrame end
    end
    return root.CFrame
end

local function bringItems(names)
    local targetCF = getTargetCF()
    local count = {}
    for _, n in ipairs(names) do count[n] = 0 end

    for _, obj in ipairs(workspace:GetDescendants()) do
        local allDone = true
        for _, n in ipairs(names) do
            if count[n] < State.MaxPerItem then allDone = false; break end
        end
        if allDone then break end

        if obj:IsA("BasePart") and not obj.Locked then
            local ch = lp.Character
            if ch and obj:IsDescendantOf(ch) then continue end
            for _, n in ipairs(names) do
                if count[n] < State.MaxPerItem and obj.Name:lower():find(n:lower()) then
                    local off = CFrame.new(math.random(-4,4), math.random(1,3), math.random(-4,4))
                    pcall(function() obj.CFrame = targetCF * off end)
                    count[n] = count[n] + 1
                    break
                end
            end
        end
    end

    local total = 0
    for _,v in pairs(count) do total += v end
    notify("Bring System", "РџРµСЂРµРјРµС‰РµРЅРѕ: " .. total .. " -> " .. State.BringTarget, 4)
end


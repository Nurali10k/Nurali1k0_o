local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")
local sgui = game:GetService("StarterGui")

local screenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
screenGui.Name = "NuraliMixGui"
screenGui.ResetOnSpawn = false

local speedValue = 2
local isFlying = false
local flyPart, flyBG, flyBV, hb, noclipConn

local function disableFly()
    if not isFlying then return end
    isFlying = false
    if hb then hb:Disconnect() end
    if noclipConn then noclipConn:Disconnect() end
    if flyBG then flyBG:Destroy() end
    if flyBV then flyBV:Destroy() end
    local char = player.Character
    if char and char:FindFirstChildOfClass("Humanoid") then
        char:FindFirstChildOfClass("Humanoid").PlatformStand = false
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end

local function enableFly()
    if isFlying then return end
    isFlying = true
    local char = player.Character or player.CharacterAdded:Wait()
    local hum = char:FindFirstChildOfClass("Humanoid")
    flyPart = char:FindFirstChild("HumanoidRootPart")
    if not flyPart or not hum then isFlying = false return end
    hum.PlatformStand = true
    flyBG = Instance.new("BodyGyro", flyPart)
    flyBG.D, flyBG.P = 15, 3000
    flyBG.MaxTorque = Vector3.new(1, 1, 1) * math.huge
    flyBV = Instance.new("BodyVelocity", flyPart)
    flyBV.MaxForce = Vector3.new(1, 1, 1) * math.huge
    local cam = workspace.CurrentCamera
    hb = runService.Heartbeat:Connect(function()
        if isFlying and flyPart and flyBG and flyBV and hum then
            flyBG.CFrame = cam.CFrame
            if hum.MoveDirection.Magnitude > 0 then
                local jitter = Vector3.new(math.random(-1,1)/100, 0, math.random(-1,1)/100)
                flyBV.Velocity = (cam.CFrame.LookVector + jitter) * (speedValue * 60)
            else
                flyBV.Velocity = Vector3.new(0, 0.1, 0)
            end
        end
    end)
    noclipConn = runService.Stepped:Connect(function()
        if isFlying then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
end

local mainFrame = Instance.new("Frame", screenGui)
mainFrame.Size = UDim2.new(0, 220, 0, 130)
mainFrame.Position = UDim2.new(0.5, -110, 0.5, -65)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.BorderSizePixel = 2
mainFrame.Active = true
mainFrame.Draggable = true

local titleBar = Instance.new("TextLabel", mainFrame)
titleBar.Size = UDim2.new(1, 0, 0, 25)
titleBar.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
titleBar.Text = "Nurali1k0_o | FLY V3"
titleBar.TextColor3 = Color3.new(1, 1, 1)
titleBar.Font = Enum.Font.SourceSansBold
titleBar.TextSize = 14

local container = Instance.new("Frame", mainFrame)
container.Size = UDim2.new(1, -10, 1, -35)
container.Position = UDim2.new(0, 5, 0, 30)
container.BackgroundTransparency = 1

local grid = Instance.new("UIGridLayout", container)
grid.CellSize = UDim2.new(0, 65, 0, 40)
grid.CellPadding = UDim2.new(0, 5, 0, 5)

local function createBtn(text, color)
    local b = Instance.new("TextButton", container)
    b.Text, b.BackgroundColor3 = text, color
    b.Font, b.TextSize = "SourceSansBold", 16
    b.TextColor3 = Color3.new(1, 1, 1)
    b.BorderSizePixel = 0
    local corner = Instance.new("UICorner", b)
    corner.CornerRadius = UDim.new(0, 4)
    return b
end

local plusBtn = createBtn("+ Speed", Color3.fromRGB(50, 200, 50))
local speedDisp = Instance.new("TextLabel", container)
speedDisp.BackgroundColor3, speedDisp.Text = Color3.fromRGB(255, 100, 0), tostring(speedValue)
speedDisp.TextColor3, speedDisp.Font, speedDisp.TextSize = Color3.new(1, 1, 1), "SourceSansBold", 20
Instance.new("UICorner", speedDisp).CornerRadius = UDim.new(0, 4)

local minusBtn = createBtn("- Speed", Color3.fromRGB(200, 50, 50))
local flyBtn = createBtn("FLY", Color3.fromRGB(130, 50, 250))
local closeBtn = createBtn("EXIT", Color3.fromRGB(20, 20, 20))
local hideBtn = createBtn("HIDE", Color3.fromRGB(60, 60, 60))

plusBtn.MouseButton1Click:Connect(function() speedValue = speedValue + 1 speedDisp.Text = tostring(speedValue) end)
minusBtn.MouseButton1Click:Connect(function() speedValue = math.max(1, speedValue - 1) speedDisp.Text = tostring(speedValue) end)
flyBtn.MouseButton1Click:Connect(function()
    if isFlying then 
        disableFly() flyBtn.Text = "FLY" flyBtn.BackgroundColor3 = Color3.fromRGB(130, 50, 250)
    else 
        enableFly() flyBtn.Text = "STOP" flyBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    end 
end)
closeBtn.MouseButton1Click:Connect(function() screenGui:Destroy() disableFly() end)

local collapsed = false
hideBtn.MouseButton1Click:Connect(function()
    collapsed = not collapsed
    container.Visible = not collapsed
    mainFrame.Size = collapsed and UDim2.new(0, 220, 0, 25) or UDim2.new(0, 220, 0, 130)
end)


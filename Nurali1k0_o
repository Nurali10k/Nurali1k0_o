    if isFlying then 
        disableFly() flyBtn.Text = "FLY" flyBtn.BackgroundColor3 = Color3.fromRGB(130, 50, 250)
    else 
        enableFly() flyBtn.Text = "STOP" flyBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    end 
end)

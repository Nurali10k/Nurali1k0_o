local player = game.Players.LocalPlayer
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "NuraliCustomUI"
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local speedValue = 50 
local isFlying = false
local flyPart, flyBG, flyBV, heartbeatConnection

local function applySpeed()
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then humanoid.WalkSpeed = speedValue end
end

local function updateSpeedDisplay()
    if screenGui:FindFirstChild("MainFrame") and screenGui.MainFrame:FindFirstChild("SpeedDisplay") then
        screenGui.MainFrame.SpeedDisplay.Text = "Скорость - " .. speedValue
    end
end

local function disableFly()
    if not isFlying then return end
    isFlying = false
    if heartbeatConnection then heartbeatConnection:Disconnect() end
    if flyBG then flyBG:Destroy(); flyBG = nil end
    if flyBV then flyBV:Destroy(); flyBV = nil end
    local character = player.Character
    if character and character:FindFirstChildOfClass("Humanoid") then
        character:FindFirstChildOfClass("Humanoid").PlatformStand = false
    end
    applySpeed()
end

local function enableFly()
    if isFlying then return end
    isFlying = true
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    flyPart = character:FindFirstChild("HumanoidRootPart")
    
    if not flyPart or not humanoid then isFlying = false return end
    
    humanoid.PlatformStand = true
    
    flyBG = Instance.new("BodyGyro", flyPart)
    flyBG.D = 10
    flyBG.P = 2000
    flyBG.MaxTorque = Vector3.new(1, 1, 1) * math.huge
    
    flyBV = Instance.new("BodyVelocity", flyPart)
    flyBV.MaxForce = Vector3.new(1, 1, 1) * math.huge
    
    local camera = workspace.CurrentCamera
    
    heartbeatConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if isFlying and flyPart and flyBG and flyBV and humanoid then
            -- Поворачиваем персонажа за камерой, чтобы перед был всегда спереди
            flyBG.CFrame = camera.CFrame
            -- Двигаемся по направлению джойстика (MoveDirection)
            flyBV.Velocity = humanoid.MoveDirection * speedValue
        end
    end)
end


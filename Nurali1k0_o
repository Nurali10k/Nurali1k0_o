local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")
local screenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
screenGui.Name = "NuraliUltraFly"
screenGui.ResetOnSpawn = false

local speedValue = 2
local isFlying = false
local flyPart, flyBG, flyBV, hb, noclipConn

local function disableFly()
    if not isFlying then return end
    isFlying = false
    if hb then hb:Disconnect() end
    if noclipConn then noclipConn:Disconnect() end
    if flyBG then flyBG:Destroy() end
    if flyBV then flyBV:Destroy() end
    local char = player.Character
    if char and char:FindFirstChildOfClass("Humanoid") then
        char:FindFirstChildOfClass("Humanoid").PlatformStand = false
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end

local function enableFly()
    if isFlying then return end
    isFlying = true
    local char = player.Character or player.CharacterAdded:Wait()
    local hum = char:FindFirstChildOfClass("Humanoid")
    flyPart = char:FindFirstChild("HumanoidRootPart")
    if not flyPart or not hum then isFlying = false return end
    hum.PlatformStand = true
    flyBG = Instance.new("BodyGyro", flyPart)
    flyBG.D, flyBG.P = 15, 3000
    flyBG.MaxTorque = Vector3.new(1, 1, 1) * math.huge
    flyBV = Instance.new("BodyVelocity", flyPart)
    flyBV.MaxForce = Vector3.new(1, 1, 1) * math.huge
    local cam = workspace.CurrentCamera
    hb = runService.Heartbeat:Connect(function()
        if isFlying and flyPart and flyBG and flyBV and hum then
            flyBG.CFrame = cam.CFrame
            if hum.MoveDirection.Magnitude > 0 then
                local jitter = Vector3.new(math.random(-1,1)/100, 0, math.random(-1,1)/100)
                flyBV.Velocity = (cam.CFrame.LookVector + jitter) * (speedValue * 60)
            else
                flyBV.Velocity = Vector3.new(0, 0.15, 0)
            end
        end
    end)
    noclipConn = runService.Stepped:Connect(function()
        if isFlying then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
end

local mainFrame = Instance.new("Frame", screenGui)
mainFrame.Size, mainFrame.Position = UDim2.new(0, 200, 0, 120), UDim2.new(0.5, -100, 0.5, -60)
mainFrame.BackgroundTransparency, mainFrame.Active, mainFrame.Draggable = 1, true, true

local grid = Instance.new("UIGridLayout", mainFrame)
grid.CellSize, grid.CellPadding = UDim2.new(0, 50, 0, 40), UDim2.new(0, 0, 0, 0)

local function createBtn(text, color)
    local b = Instance.new("TextButton", mainFrame)
    b.Text, b.BackgroundColor3 = text, color
    b.BorderSizePixel, b.BorderColor3 = 1, Color3.new(0,0,0)
    b.TextColor3, b.Font, b.TextSize = Color3.new(0,0,0), "SourceSansBold", 16
    return b
end

local closeBtn = createBtn("X", Color3.fromRGB(255, 0, 0))
closeBtn.MouseButton1Click:Connect(function() screenGui:Destroy(); disableFly() end)
local hideBtn = createBtn("-", Color3.fromRGB(200, 160, 255))
local upBtn = createBtn("UP", Color3.fromRGB(150, 255, 150))
local plusBtn = createBtn("+", Color3.fromRGB(160, 180, 255))
local title = Instance.new("TextLabel", mainFrame)
title.Size, title.BackgroundColor3, title.Text = UDim2.new(0, 100, 0, 40), Color3.fromRGB(255, 100, 255), "ULTRA FLY"
title.TextColor3, title.Font, title.TextSize = Color3.new(0,0,0), "SourceSansBold", 12
local downBtn = createBtn("DOWN", Color3.fromRGB(220, 255, 160))
local minusBtn = createBtn("-", Color3.fromRGB(180, 255, 255))
local speedVal = Instance.new("TextLabel", mainFrame)
speedVal.BackgroundColor3, speedVal.Text = Color3.fromRGB(255, 100, 0), tostring(speedValue)
speedVal.TextColor3, speedVal.TextSize = Color3.new(0,0,0), 20
local flyBtn = createBtn("FLY", Color3.fromRGB(255, 255, 100))

local function updateSpeed(v) speedValue = math.max(1, speedValue + v); speedVal.Text = tostring(speedValue) end
upBtn.MouseButton1Click:Connect(function() updateSpeed(1) end)
plusBtn.MouseButton1Click:Connect(function() updateSpeed(1) end)
downBtn.MouseButton1Click:Connect(function() updateSpeed(-1) end)
minusBtn.MouseButton1Click:Connect(function() updateSpeed(-1) end)
flyBtn.MouseButton1Click:Connect(function() if isFlying then disableFly() else enableFly() end end)

local collapsed = false
hideBtn.MouseButton1Click:Connect(function()
    collapsed = not collapsed
    for _, v in pairs(mainFrame:GetChildren()) do
        if (v:IsA("TextButton") or v:IsA("TextLabel")) and v ~= hideBtn and v ~= closeBtn then v.Visible = not collapsed end
    end
    hideBtn.Text = collapsed and "+" or "-"
end)

player.CharacterAdded:Connect(function() task.wait(0.5); disableFly() end)

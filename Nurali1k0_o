local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")
local sgui = game:GetService("StarterGui")

local screenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
screenGui.Name = "NuraliUltraV3_Final"
screenGui.ResetOnSpawn = false

local speedValue = 2
local isFlying = false
local flyPart, flyBG, flyBV, hb, noclipConn

local function disableFly()
    if not isFlying then return end
    isFlying = false
    if hb then hb:Disconnect() end
    if noclipConn then noclipConn:Disconnect() end
    if flyBG then flyBG:Destroy() end
    if flyBV then flyBV:Destroy() end
    local char = player.Character
    if char and char:FindFirstChildOfClass("Humanoid") then
        char:FindFirstChildOfClass("Humanoid").PlatformStand = false
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end

local function enableFly()
    if isFlying then return end
    isFlying = true
    local char = player.Character or player.CharacterAdded:Wait()
    local hum = char:FindFirstChildOfClass("Humanoid")
    flyPart = char:FindFirstChild("HumanoidRootPart")
    if not flyPart or not hum then isFlying = false return end
    hum.PlatformStand = true
    flyBG = Instance.new("BodyGyro", flyPart)
    flyBG.D, flyBG.P = 15, 3000
    flyBG.MaxTorque = Vector3.new(1, 1, 1) * math.huge
    flyBV = Instance.new("BodyVelocity", flyPart)
    flyBV.MaxForce = Vector3.new(1, 1, 1) * math.huge
    local cam = workspace.CurrentCamera
    hb = runService.Heartbeat:Connect(function()
        if isFlying and flyPart and flyBG and flyBV and hum then
            flyBG.CFrame = cam.CFrame
            if hum.MoveDirection.Magnitude > 0 then
                local jitter = Vector3.new(math.random(-1,1)/100, 0, math.random(-1,1)/100)
                flyBV.Velocity = (cam.CFrame.LookVector + jitter) * (speedValue * 60)
            else
                flyBV.Velocity = Vector3.new(0, 0.1, 0)
            end
        end
    end)
    noclipConn = runService.Stepped:Connect(function()
        if isFlying then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
end

